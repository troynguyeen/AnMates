{
  "name": "anmates",
  "private": true,
  "scripts": {
    "dev": "docker compose --env-file .env up",
    "dev:build": "docker compose --env-file .env up --build",
    "dev:down": "docker compose --env-file .env down",
    "dev:logs": "docker compose --env-file .env logs -f",
    "dev:ps": "docker compose --env-file .env ps",
    "dev:api": "docker compose --env-file .env up api db",
    "dev:web": "docker compose --env-file .env up flutter_web",
    "test:smoke": "cd anmates-api && go test ./smoke/... -v -count=1",
    "test:e2e": "node scripts/run-flutter.mjs --cwd anmates_flutter test integration_test/",
    "test:e2e:chrome": "node scripts/run-flutter.mjs --cwd anmates_flutter test integration_test/ -d chrome",
    "load-test": "wsl bash load-test/run.sh",
    "load-test:clean": "wsl bash load-test/run.sh -c",
    "load-test:smoke": "wsl bash load-test/run.sh -v 50 -u 100"
  },
  "dependencies": {
    "firebase": "^12.13.0"
  }
}
