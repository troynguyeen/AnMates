# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:CHANGE_ME@db:5432/anmates
DB_PASS=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_xxxxxxxxx
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=168h

# ── API ───────────────────────────────────────────────────────────────────────
PORT=8080
ENV=production

# ── Firebase ──────────────────────────────────────────────────────────────────
# lấy từ Firebase Console > Project Settings > General > Web API Key
FIREBASE_WEB_API_KEY=CHANGE_ME

# ── Flutter web ───────────────────────────────────────────────────────────────
# Cổng phục vụ Flutter web khi chạy qua docker-compose.
FLUTTER_WEB_PORT=54180
# URL backend cho Flutter web ở chế độ dev (build-time --dart-define).
API_BASE_URL=http://localhost:8080

# ── Dev flags (toggle here) ──────────────────────────────────────────────────
DEV_MODE=true
DEV_BYPASS_SECRET=dev-local-2026
DISABLE_RATE_LIMIT=1
