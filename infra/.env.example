# Copy to .env and fill before `docker compose up`.
# Never commit the populated .env file.

# Public hostname; Caddy obtains a Let's Encrypt cert for this.
DOMAIN=anmates.example.com

# PostgreSQL
POSTGRES_DB=anmates
POSTGRES_USER=anmates_app
POSTGRES_PASSWORD=__generate_with__openssl_rand_base64_32__

# MinIO object storage
MINIO_ROOT_USER=anmates_minio
MINIO_ROOT_PASSWORD=__generate_with__openssl_rand_base64_32__

# JWT signing key — must be >= 256 bits (44 base64 chars).
#   openssl rand -base64 64
JWT_SIGNING_KEY=__generate_with__openssl_rand_base64_64__
