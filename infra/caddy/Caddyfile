# Caddyfile — TLS termination + reverse proxy for AnMates.
# Two virtual hosts: api.<DOMAIN> for the .NET API, files.<DOMAIN> for the MinIO console.
# Real client IP is forwarded so the application's rate limiter can partition by it.

{
	# Tighten defaults: HTTP/3 on, admin API disabled outside container.
	admin off
	servers {
		protocols h1 h2 h3
	}
	email ops@{$DOMAIN}
}

# Public API ───────────────────────────────────────────────────────────────
api.{$DOMAIN} {
	encode zstd gzip

	# Security headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), microphone=(), camera=(self)"
		-Server
	}

	# Liveness probe — never goes through the app rate limiter.
	handle /health {
		respond "ok" 200
	}

	# SignalR uses websockets; Caddy auto-detects upgrade headers.
	reverse_proxy {$API_UPSTREAM} {
		# Trust the immediate hop (the docker network) for X-Forwarded-* headers.
		trusted_proxies private_ranges
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
		transport http {
			# SignalR can keep connections open for hours.
			read_timeout 30m
			write_timeout 30m
			keepalive 30s
		}
	}

	log {
		output stdout
		format json
	}
}

# MinIO console (internal use; restrict to admin IPs in production) ─────────
files.{$DOMAIN} {
	encode zstd gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	reverse_proxy {$MINIO_CONSOLE_UPSTREAM}
}

# Root: redirect to API docs.
{$DOMAIN} {
	redir https://api.{$DOMAIN}/swagger 302
}
