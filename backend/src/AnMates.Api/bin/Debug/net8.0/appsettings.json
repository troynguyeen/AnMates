{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "StackExchange.Redis": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "GrafanaLoki",
        "Args": { "uri": "http://loki:3100" }
      }
    ]
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=anmates;Username=anmates_app;Password=__set_via_env__;Pooling=true",
    "Redis": "redis:6379,abortConnect=false,connectTimeout=2000,syncTimeout=2000"
  },
  "Jwt": {
    "Issuer": "https://anmates.example.com",
    "Audience": "anmates-mobile",
    "SigningKey": "__set_via_env__"
  },
  "RateLimit": {
    "Capacity": 5,
    "RefillRatePerSecond": 0.5,
    "KeyPrefix": "rl:v1",
    "LimitAnonymousByIp": true,
    "BypassPathPrefixes": ["/health", "/ready", "/metrics", "/swagger"],
    "RedisFailureFailOpenAfterMs": 1000
  },
  "Storage": {
    "Endpoint": "http://minio:9000",
    "Bucket": "anmates"
  },
  "AllowedHosts": "*"
}
